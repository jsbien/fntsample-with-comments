  Script: DFLT
    Language: default
      Feature: aalt
        Lookups: 0,1
      Feature: c2sc
        Lookups: 204
...
      Feature: ccmp
        Lookups: 50,53,55,56,57,58,59,60,61,...
      Feature: cv01
        Lookups: 110
      Feature: cv02
